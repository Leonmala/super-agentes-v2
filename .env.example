# ============================================================
# Super Agentes - Teste 6 | Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env — apenas o .env.example
# ============================================================


# ------------------------------------------------------------
# SUPABASE (obrigatório)
# Projeto: https://supabase.com/dashboard
# Use a "service_role" key (não a "anon" key)
# ------------------------------------------------------------
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua-service-role-key-aqui


# ------------------------------------------------------------
# OPENROUTER (obrigatório)
# Chave em: https://openrouter.ai/keys
# Uma única chave acessa todos os modelos disponíveis
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui


# ------------------------------------------------------------
# MODELOS POR PERSONA
#
# Modelo padrão (fallback para qualquer persona não configurada):
LLM_MODEL_DEFAULT=moonshotai/kimi-k2:free
#
# Persona PSICOPEDAGOGICO — qualificação e acolhimento
LLM_MODEL_PSICOPEDAGOGICO=moonshotai/kimi-k2:free
#
# Persona CALCULUS — matemática
LLM_MODEL_CALCULUS=moonshotai/kimi-k2:free
#
# Persona VERBETA — português
# Gemini 2.5 Flash tem excelente desempenho em PT-BR
# Alternativas: google/gemini-2.0-flash-001, anthropic/claude-3-haiku
LLM_MODEL_VERBETA=google/gemini-2.5-flash


# ------------------------------------------------------------
# CONFIGURAÇÕES DO SERVIDOR
# ------------------------------------------------------------

# Porta local (Railway injeta PORT automaticamente em produção)
PORT=3000

# URL da aplicação — usada no header HTTP-Referer do OpenRouter
# Em produção: substitua pela URL do Railway gerada
APP_URL=http://localhost:3000

# Timeout da chamada ao LLM em milissegundos (padrão: 30000 = 30s)
LLM_TIMEOUT_MS=30000
