# ============================================================
# Super Agentes - Teste 6 v2_fast | Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env — apenas o .env.example
# ============================================================


# ------------------------------------------------------------
# GOOGLE AI / GEMINI (obrigatório)
# Chave em: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GOOGLE_API_KEY=sua-chave-gemini-aqui

# Modelo para heróis (respostas educativas)
GEMINI_MODEL=gemini-2.0-flash

# Modelo para PSICO (mais rápido, só JSON)
GEMINI_MODEL_PSICO=gemini-2.5-flash


# ------------------------------------------------------------
# SUPABASE (obrigatório)
# Projeto: https://supabase.com/dashboard
# Use a "service_role" key (não a "anon" key)
# ------------------------------------------------------------
SUPABASE_URL=https://ahopvaekwejpsxzzrvux.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui


# ------------------------------------------------------------
# CONFIGURAÇÕES DO SERVIDOR
# ------------------------------------------------------------

# Porta local (Railway injeta PORT automaticamente em produção)
PORT=3000

# Timeout da chamada ao LLM em milissegundos (padrão: 60000 = 60s)
LLM_TIMEOUT_MS=60000
